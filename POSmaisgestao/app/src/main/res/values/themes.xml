<resources>
    <!-- Tema claro fixo: POS precisa de contraste alto em telas pequenas -->
    <style name="Base.Theme.POSmaisgestao" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnPrimary">@color/primary_foreground</item>
        <item name="colorOnSurface">@color/foreground</item>
        <item name="colorOnBackground">@color/foreground</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/surface</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:textColorPrimary">@color/foreground</item>
        <item name="android:textColorSecondary">@color/muted_foreground</item>
        <item name="android:textColor">@color/foreground</item>
        <item name="android:textColorHint">@color/muted_foreground</item>
    </style>

    <style name="Theme.POSmaisgestao" parent="Base.Theme.POSmaisgestao" />

    <style name="PosBigButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">72dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">8dp</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/primary_foreground</item>
    </style>

    <style name="PosHubButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">120dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/primary_foreground</item>
    </style>

    <style name="PosSectionTitle">
        <item name="android:textColor">@color/foreground</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PosBodyText">
        <item name="android:textColor">@color/foreground</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="PosHelpText">
        <item name="android:textColor">@color/muted_foreground</item>
        <item name="android:textSize">13sp</item>
    </style>
</resources>
