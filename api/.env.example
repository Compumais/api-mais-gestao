# URL de conexão com o banco de dados PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mais_gestao

# URL pública da API (usada pelo Better Auth e Swagger)
API_URL=http://localhost:3333

# URL pública do front-end (origem permitida no CORS e Better Auth)
FRONTEND_URL=http://localhost:3000

# Origens permitidas no CORS (separadas por vírgula). Se vazio, usa FRONTEND_URL.
# Exemplo VPS: CORS_ORIGINS=http://203.0.113.10:3000
CORS_ORIGINS=

# Configurações do Better Auth
BETTER_AUTH_SECRET=sua-chave-secreta-aqui
BETTER_AUTH_URL=http://localhost:3333
USE_SECURE_COOKIES=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=