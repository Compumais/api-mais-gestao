{
	"name": "api-mais-gestao",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"scripts": {
		"start": "node dist/src/index.js",
		"dev": "tsx watch src/index.ts",
		"build": "tsc && npx tsc-alias -p tsconfig.json && node scripts/fix-dist-esm-imports.mjs && node -e \"console.log('\\nBuild da API concluído com sucesso.')\"",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"test:unit": "vitest run",
		"test:e2e": "vitest run --config vitest.config.e2e.ts",
		"test:watch": "vitest watch",
		"seed": "tsx drizzle/seed.ts",
		"clean": "tsx drizzle/clean.ts",
		"db:patch-roles": "tsx drizzle/patch-roles.ts",
		"db:push": "tsx node_modules/drizzle-kit/bin.cjs push",
		"db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
		"db:studio": "tsx node_modules/drizzle-kit/bin.cjs studio",
		"db:migrate": "tsx node_modules/drizzle-kit/bin.cjs migrate",
		"db:migrate:undo": "tsx node_modules/drizzle-kit/bin.cjs migrate:undo",
		"db:migrate:latest": "tsx node_modules/drizzle-kit/bin.cjs migrate:latest",
		"db:migrate:rollback": "tsx node_modules/drizzle-kit/bin.cjs migrate:rollback",
		"db:migrate:status": "tsx node_modules/drizzle-kit/bin.cjs migrate:status",
		"db:migrate:reset": "tsx node_modules/drizzle-kit/bin.cjs migrate:reset",
		"db:migrate:force": "tsx node_modules/drizzle-kit/bin.cjs migrate:force",
		"db:migrate:revert": "tsx node_modules/drizzle-kit/bin.cjs migrate:revert"
	},
	"keywords": [],
