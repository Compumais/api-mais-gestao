		"@fastify/swagger-ui": "^5.2.4",
		"bcryptjs": "^2.4.3",
		"better-auth": "^1.5.5",
		"dotenv": "^17.2.3",
		"drizzle-orm": "^0.44.7",
		"fastify": "^5.6.2",
		"pg": "^8.16.3",
		"uuid": "^13.0.0",
		"zod": "^4.1.13",
		"zod-to-json-schema": "^3.25.1"
	},
	"devDependencies": {
