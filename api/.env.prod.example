# Banco de dados de produção
DATABASE_URL=postgresql://mais_gestao:<PASSWORD>@127.0.0.1:5432/mais_gestao

# URL pública da API
API_URL=https://api.seudominio.com

# URL pública do front-end
FRONTEND_URL=https://app.seudominio.com

# Origens CORS (separadas por vírgula). Obrigatório em produção com IP/domínio público.
# Exemplo com IP: CORS_ORIGINS=http://203.0.113.10:3000
CORS_ORIGINS=https://app.seudominio.com

# Better Auth
BETTER_AUTH_SECRET=<GERAR_COM_openssl_rand_base64_32>
BETTER_AUTH_URL=https://api.seudominio.com
USE_SECURE_COOKIES=true

# OAuth Google (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
