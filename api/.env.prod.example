# Banco de dados de produção
DATABASE_URL=postgresql://mais_gestao:<PASSWORD>@127.0.0.1:5432/mais_gestao

# URL pública da API
API_URL=https://api.compuchat.space

# URL pública do front-end (origem permitida no CORS e Better Auth)
FRONTEND_URL=https://mais.compuchat.space

# Alias legado do front-end (também aceito pelo CORS se FRONTEND_URL não estiver definido)
CLIENT_ORIGIN=https://mais.compuchat.space

# Origens CORS adicionais (separadas por vírgula)
CORS_ORIGINS=https://mais.compuchat.space

# Better Auth — URL pública da API
BETTER_AUTH_SECRET=<GERAR_COM_openssl_rand_base64_32>
BETTER_AUTH_URL=https://api.compuchat.space
USE_SECURE_COOKIES=true

# Compartilha cookie de sessão entre api.* e mais.* (obrigatório com front e API em subdomínios diferentes)
COOKIE_DOMAIN=compuchat.space

# OAuth Google (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Datadog APM (opcional — requer dd-trace na API e Agent no host)
# DD_ENV=prod
# DD_SERVICE=api-mais-gestao
# DD_VERSION=1.0.0
# DD_TRACE_ENABLED=true
# DD_LOGS_INJECTION=true
# DD_AGENT_HOST=host.docker.internal
